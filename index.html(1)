<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chanda's Collateral Based Loans – Fast Loans in Kitwe & Ndola</title>
  <meta name="description" content="Chanda's Collateral Based Loans – Get a collateral-based loan in just a few minutes. Serving Kitwe and Ndola, Zambia." />
  <meta name="keywords" content="collateral loans Zambia, loans Kitwe, loans Ndola, fast loans Zambia, phone collateral loan, laptop collateral loan" />
  <meta name="robots" content="index, follow" />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@700;800&display=swap" rel="stylesheet" />

  <style>
    :root {
      --black:   #050a04;
      --dark:    #0a1209;
      --dark2:   #0f1a0d;
      --green:   #1a7a2e;
      --green2:  #22a03c;
      --lime:    #8bc34a;
      --gold:    #f5c842;
      --gold2:   #c9980a;
      --white:   #f0f5ee;
      --muted:   #5a7055;
      --border:  rgba(139,195,74,.18);
      --glow-g:  0 0 28px rgba(34,160,60,.4);
      --glow-y:  0 0 28px rgba(245,200,66,.45);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Barlow', sans-serif;
      background: var(--black);
      color: var(--white);
      overflow-x: hidden;
    }

    /* ── MONEY TEXTURE BACKGROUND ── */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background-image:
        repeating-linear-gradient(
          45deg,
          transparent,
          transparent 60px,
          rgba(26,122,46,.03) 60px,
          rgba(26,122,46,.03) 61px
        ),
        repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 60px,
          rgba(26,122,46,.03) 60px,
          rgba(26,122,46,.03) 61px
        );
      pointer-events: none;
    }

    section, nav, footer { position: relative; z-index: 1; }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 6vw; height: 66px;
      background: rgba(5,10,4,.93);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }

    .nav-brand {
      display: flex; align-items: center; gap: .7rem;
      text-decoration: none;
    }
    .nav-coin {
      width: 40px; height: 40px; border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--gold2));
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; box-shadow: var(--glow-y);
      flex-shrink: 0;
    }
    .nav-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.25rem; letter-spacing: 2px;
      color: var(--white); line-height: 1.1;
    }
    .nav-name span { color: var(--gold); }

    .nav-links { display: flex; gap: 1.8rem; list-style: none; }
    .nav-links a {
      text-decoration: none; color: var(--muted);
      font-size: .82rem; font-weight: 600; letter-spacing: 1px;
      text-transform: uppercase; transition: color .2s;
    }
    .nav-links a:hover { color: var(--lime); }
    .nav-apply {
      background: var(--gold) !important; color: var(--black) !important;
      padding: .4rem 1.2rem; border-radius: 3px;
      transition: box-shadow .2s !important;
    }
    .nav-apply:hover { box-shadow: var(--glow-y) !important; color: var(--black) !important; }

    /* ── HERO ── */
    #hero {
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding: 110px 6vw 80px;
      background:
        radial-gradient(ellipse 80% 60% at 50% 30%, rgba(26,122,46,.22) 0%, transparent 65%),
        radial-gradient(ellipse 50% 40% at 80% 80%, rgba(245,200,66,.08) 0%, transparent 55%);
    }

    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: .5rem;
      font-size: .72rem; letter-spacing: 3px; text-transform: uppercase;
      color: var(--lime); border: 1px solid rgba(139,195,74,.3);
      padding: .38rem 1.1rem; border-radius: 2px; margin-bottom: 2rem;
      animation: fadeUp .7s ease both;
    }
    .hero-eyebrow::before { content: '●'; font-size: .5rem; animation: pulse 2s ease infinite; }
    @keyframes pulse { 0%,100%{opacity:.3} 50%{opacity:1} }

    .hero-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.5rem, 9vw, 7rem);
      letter-spacing: 3px; line-height: .95;
      animation: fadeUp .7s .08s ease both;
    }
    .hero-title .g { color: var(--green2); }
    .hero-title .y { color: var(--gold); }

    .hero-sub {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
      color: var(--muted); margin: 1.2rem 0 2.8rem;
      animation: fadeUp .7s .16s ease both;
    }

    .hero-btns {
      display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
      animation: fadeUp .7s .24s ease both;
    }
    .btn-gold {
      background: var(--gold); color: var(--black);
      font-family: 'Barlow Condensed', sans-serif; font-size: 1rem;
      font-weight: 800; letter-spacing: 2px; text-transform: uppercase;
      padding: .9rem 2.4rem; border: none; border-radius: 3px;
      cursor: pointer; text-decoration: none;
      transition: box-shadow .2s, transform .15s;
    }
    .btn-gold:hover { box-shadow: var(--glow-y); transform: translateY(-2px); }
    .btn-outline {
      background: transparent; color: var(--white);
      font-family: 'Barlow Condensed', sans-serif; font-size: 1rem;
      font-weight: 800; letter-spacing: 2px; text-transform: uppercase;
      padding: .9rem 2.4rem; border: 1px solid rgba(255,255,255,.18);
      border-radius: 3px; cursor: pointer; text-decoration: none;
      transition: border-color .2s, color .2s;
    }
    .btn-outline:hover { border-color: var(--lime); color: var(--lime); }

    /* hero stat strip */
    .hero-stats {
      display: flex; gap: 0; margin-top: 4rem; flex-wrap: wrap; justify-content: center;
      border: 1px solid var(--border); border-radius: 6px; overflow: hidden;
      animation: fadeUp .7s .35s ease both;
    }
    .hero-stat {
      padding: 1.2rem 2.5rem; text-align: center;
      border-right: 1px solid var(--border);
    }
    .hero-stat:last-child { border-right: none; }
    .hero-stat .num {
      font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem;
      color: var(--gold); letter-spacing: 1px; line-height: 1;
    }
    .hero-stat .lbl { font-size: .72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-top: .2rem; }

    /* ── RATES ── */
    #rates { padding: 100px 6vw; background: var(--dark); }

    .section-tag {
      font-size: .7rem; letter-spacing: 3px; text-transform: uppercase;
      color: var(--lime); margin-bottom: .7rem;
    }
    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      letter-spacing: 2px; margin-bottom: 1rem; line-height: 1;
    }
    .section-desc { color: var(--muted); font-size: .95rem; line-height: 1.7; max-width: 520px; margin-bottom: 3rem; }

    .rates-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.2rem;
    }
    .rate-card {
      background: var(--dark2); border: 1px solid var(--border);
      border-radius: 6px; padding: 1.8rem 1.4rem; text-align: center;
      position: relative; overflow: hidden;
      transition: transform .25s, box-shadow .25s, border-color .25s;
    }
    .rate-card::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0;
      height: 3px; background: linear-gradient(90deg, var(--green), var(--gold));
      transform: scaleX(0); transition: transform .3s; transform-origin: left;
    }
    .rate-card:hover { transform: translateY(-5px); box-shadow: var(--glow-g); border-color: rgba(139,195,74,.35); }
    .rate-card:hover::after { transform: scaleX(1); }
    .rate-weeks { font-family: 'Bebas Neue', sans-serif; font-size: 3rem; color: var(--gold); letter-spacing: 2px; line-height: 1; }
    .rate-label { font-size: .75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: .6rem; }
    .rate-percent { font-family: 'Barlow Condensed', sans-serif; font-size: 2rem; font-weight: 800; color: var(--lime); }
    .rate-interest { font-size: .75rem; color: var(--muted); margin-top: .3rem; }

    /* ── COLLATERAL ── */
    #collateral { padding: 100px 6vw; background: var(--black); }

    .collateral-inner { display: flex; gap: 5vw; flex-wrap: wrap; align-items: center; }
    .collateral-text { flex: 1 1 320px; }
    .collateral-grid {
      flex: 1 1 320px;
      display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    }
    .collateral-card {
      background: var(--dark2); border: 1px solid var(--border);
      border-radius: 6px; padding: 1.6rem 1.2rem;
      display: flex; align-items: center; gap: 1rem;
      transition: border-color .2s, background .2s;
    }
    .collateral-card:hover { border-color: var(--gold2); background: rgba(245,200,66,.04); }
    .collateral-icon { font-size: 2rem; flex-shrink: 0; }
    .collateral-card h4 { font-weight: 700; font-size: .95rem; }
    .collateral-card p { font-size: .78rem; color: var(--muted); margin-top: .2rem; }

    /* ── HOW IT WORKS ── */
    #how { padding: 100px 6vw; background: var(--dark); }
    .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 3rem; }
    .step {
      position: relative; padding: 2rem 1.4rem;
      background: var(--dark2); border: 1px solid var(--border); border-radius: 6px;
    }
    .step-num {
      font-family: 'Bebas Neue', sans-serif; font-size: 4rem; line-height: 1;
      color: rgba(139,195,74,.12); position: absolute; top: .8rem; right: 1rem;
      user-select: none;
    }
    .step-icon { font-size: 1.8rem; margin-bottom: .8rem; }
    .step h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 1.1rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-bottom: .5rem; }
    .step p { font-size: .85rem; color: var(--muted); line-height: 1.6; }

    /* ── CONTRACT / APPLY ── */
    #apply { padding: 100px 6vw; background: var(--black); }

    .apply-header { text-align: center; margin-bottom: 3rem; }
    .apply-header .section-desc { margin: 0 auto; }

    .contract-wrap {
      max-width: 860px; margin: 0 auto;
      background: var(--dark2); border: 1px solid var(--border); border-radius: 10px;
      overflow: hidden;
    }

    /* Contract header band */
    .contract-header {
      background: linear-gradient(135deg, var(--green) 0%, #0f3d1a 100%);
      padding: 2rem 2.5rem; border-bottom: 3px solid var(--gold);
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    }
    .contract-logo { display: flex; align-items: center; gap: .8rem; }
    .contract-coin { width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg, var(--gold), var(--gold2)); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .contract-brand-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; letter-spacing: 2px; color: var(--white); }
    .contract-brand-sub { font-size: .72rem; color: rgba(255,255,255,.6); text-transform: uppercase; letter-spacing: 2px; }
    .contract-title-block { text-align: right; }
    .contract-doc-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 2px; color: var(--gold); }
    .contract-doc-sub { font-size: .72rem; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: 1px; }

    .contract-body { padding: 2rem 2.5rem; }

    /* Section dividers inside contract */
    .form-section { margin-bottom: 2rem; }
    .form-section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .8rem; font-weight: 800; letter-spacing: 3px;
      text-transform: uppercase; color: var(--gold);
      border-bottom: 1px solid rgba(245,200,66,.2);
      padding-bottom: .5rem; margin-bottom: 1.2rem;
      display: flex; align-items: center; gap: .5rem;
    }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-grid.three { grid-template-columns: 1fr 1fr 1fr; }
    .form-grid.full { grid-template-columns: 1fr; }

    .form-group { display: flex; flex-direction: column; gap: .35rem; }
    .form-group label {
      font-size: .7rem; letter-spacing: 1.5px; text-transform: uppercase;
      color: var(--muted); font-weight: 600;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      background: rgba(255,255,255,.04); border: 1px solid rgba(139,195,74,.2);
      border-radius: 4px; padding: .7rem .9rem; color: var(--white);
      font-family: 'Barlow', sans-serif; font-size: .9rem; outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--lime);
      box-shadow: 0 0 0 3px rgba(139,195,74,.1);
    }
    .form-group select option { background: var(--dark2); }
    .form-group textarea { resize: vertical; min-height: 80px; }
    .form-group input[type="file"] {
      padding: .5rem .9rem; cursor: pointer; color: var(--muted);
    }

    /* Loan amount display */
    .loan-calc {
      background: rgba(245,200,66,.06); border: 1px solid rgba(245,200,66,.2);
      border-radius: 6px; padding: 1.2rem 1.4rem; margin-bottom: 1.5rem;
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .8rem;
    }
    .loan-calc .lc-label { font-size: .75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
    .loan-calc .lc-val { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; color: var(--gold); letter-spacing: 1px; }

    /* Terms box */
    .terms-box {
      background: rgba(0,0,0,.3); border: 1px solid var(--border);
      border-radius: 4px; padding: 1.2rem; margin-bottom: 1.5rem;
      font-size: .8rem; color: var(--muted); line-height: 1.7; max-height: 160px;
      overflow-y: auto;
    }
    .terms-box::-webkit-scrollbar { width: 4px; }
    .terms-box::-webkit-scrollbar-thumb { background: var(--green); border-radius: 2px; }
    .terms-box strong { color: var(--white); }

    /* Checkbox */
    .check-row {
      display: flex; align-items: flex-start; gap: .75rem; margin-bottom: 1.2rem;
      cursor: pointer;
    }
    .check-row input[type="checkbox"] {
      width: 18px; height: 18px; accent-color: var(--lime);
      flex-shrink: 0; margin-top: 2px; cursor: pointer;
    }
    .check-row span { font-size: .85rem; color: var(--muted); line-height: 1.5; }
    .check-row span strong { color: var(--white); }

    /* Signature area */
    .sig-area {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;
    }
    .sig-box {
      border-bottom: 1px solid rgba(139,195,74,.3);
      padding-bottom: .5rem; text-align: center;
    }
    .sig-box .sig-line { height: 52px; }
    .sig-box .sig-label { font-size: .7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-top: .4rem; }

    .submit-contract {
      width: 100%; background: linear-gradient(135deg, var(--green2), var(--green));
      color: var(--white); font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem; letter-spacing: 3px; padding: 1.1rem;
      border: none; border-radius: 4px; cursor: pointer;
      transition: box-shadow .2s, transform .15s;
    }
    .submit-contract:hover { box-shadow: var(--glow-g); transform: translateY(-2px); }

    .contract-footer-note {
      text-align: center; font-size: .75rem; color: var(--muted);
      margin-top: 1rem; line-height: 1.6;
    }

    /* Success state */
    .contract-success {
      display: none; text-align: center; padding: 3rem 2rem;
    }
    .contract-success .big-check { font-size: 4rem; margin-bottom: 1rem; }
    .contract-success h3 { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--lime); margin-bottom: .5rem; }
    .contract-success p { color: var(--muted); font-size: .92rem; line-height: 1.7; max-width: 420px; margin: 0 auto 1.5rem; }

    /* ── CONTACT ── */
    #contact { padding: 100px 6vw; background: var(--dark); }
    .contact-inner { display: flex; gap: 4vw; flex-wrap: wrap; align-items: flex-start; }
    .contact-left { flex: 1 1 300px; }
    .contact-cards { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
    .contact-card {
      background: var(--dark2); border: 1px solid var(--border); border-radius: 6px;
      padding: 1.2rem 1.4rem; display: flex; align-items: center; gap: 1rem;
      text-decoration: none; color: var(--white); transition: border-color .2s, box-shadow .2s;
    }
    .contact-card:hover { border-color: var(--gold2); box-shadow: var(--glow-y); }
    .contact-card .cc-icon { font-size: 1.5rem; flex-shrink: 0; }
    .contact-card .cc-lbl { font-size: .7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
    .contact-card .cc-val { font-family: 'Barlow Condensed', sans-serif; font-size: 1.15rem; font-weight: 800; color: var(--gold); letter-spacing: .5px; }
    .contact-right {
      flex: 1 1 300px; background: linear-gradient(135deg, rgba(26,122,46,.08), rgba(245,200,66,.06));
      border: 1px solid var(--border); border-radius: 8px; padding: 2.5rem;
    }
    .contact-right h3 { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; margin-bottom: .5rem; }
    .contact-right h3 span { color: var(--gold); }
    .contact-right p { color: var(--muted); font-size: .9rem; line-height: 1.7; margin-bottom: 1.2rem; }
    .location-badge {
      display: inline-flex; align-items: center; gap: .5rem;
      background: rgba(245,200,66,.1); border: 1px solid rgba(245,200,66,.25);
      border-radius: 3px; padding: .5rem 1rem; font-size: .85rem; color: var(--gold);
      font-weight: 600;
    }

    /* ── FOOTER ── */
    footer {
      background: var(--dark); border-top: 1px solid var(--border);
      padding: 2rem 6vw; text-align: center;
      font-size: .78rem; color: var(--muted);
    }
    footer span { color: var(--gold); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .reveal { opacity: 0; transform: translateY(26px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 680px) {
      .nav-links { display: none; }
      .form-grid, .form-grid.three { grid-template-columns: 1fr; }
      .sig-area { grid-template-columns: 1fr; }
      .hero-stat { padding: .9rem 1.4rem; }
      .contract-header { flex-direction: column; }
      .contract-title-block { text-align: left; }
      .loan-calc { flex-direction: column; gap: .4rem; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#hero" class="nav-brand">
    <div class="nav-coin">💰</div>
    <div>
      <div class="nav-name">CHANDA'S <span>LOANS</span></div>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="#rates">Rates</a></li>
    <li><a href="#collateral">Collateral</a></li>
    <li><a href="#how">How It Works</a></li>
    <li><a href="#apply" class="nav-apply">Apply Now</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-eyebrow">Fast Loans · Kitwe &amp; Ndola · Zambia</div>
  <h1 class="hero-title">
    LOOKING FOR<br>
    <span class="g">A </span><span class="y">LOAN?</span>
  </h1>
  <p class="hero-sub">Get a collateral-based loan in just a few minutes</p>
  <div class="hero-btns">
    <a href="#apply" class="btn-gold">Apply Now</a>
    <a href="#rates" class="btn-outline">View Rates</a>
  </div>
  <div class="hero-stats">
    <div class="hero-stat"><div class="num">4</div><div class="lbl">Loan Durations</div></div>
    <div class="hero-stat"><div class="num">15%</div><div class="lbl">Starting Rate</div></div>
    <div class="hero-stat"><div class="num">⚡</div><div class="lbl">Fast Approval</div></div>
    <div class="hero-stat"><div class="num">2</div><div class="lbl">Locations</div></div>
  </div>
</section>

<!-- RATES -->
<section id="rates">
  <div class="section-tag reveal">Loan Rates</div>
  <h2 class="section-title reveal">Clear &amp; Simple<br>Interest Rates</h2>
  <p class="section-desc reveal">No hidden fees. Choose the duration that works for you and know exactly what you owe.</p>
  <div class="rates-grid">
    <div class="rate-card reveal">
      <div class="rate-label">Duration</div>
      <div class="rate-weeks">1</div>
      <div class="rate-label">Week</div>
      <div class="rate-percent">15%</div>
      <div class="rate-interest">Interest rate</div>
    </div>
    <div class="rate-card reveal">
      <div class="rate-label">Duration</div>
      <div class="rate-weeks">2</div>
      <div class="rate-label">Weeks</div>
      <div class="rate-percent">25%</div>
      <div class="rate-interest">Interest rate</div>
    </div>
    <div class="rate-card reveal">
