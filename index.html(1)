<script>
  // ── Scroll reveal
  const revEls = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver(entries => {
    entries.forEach((e,i) => {
      if (e.isIntersecting) { setTimeout(() => e.target.classList.add('visible'), i*70); obs.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  revEls.forEach(el => obs.observe(el));

  // ── Set contract date & ref on load
  function genRef() {
    return 'CCL-' + Date.now().toString(36).toUpperCase().slice(-6);
  }
  const today = new Date();
  const dateStr = today.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
  document.getElementById('contractRef').textContent = genRef();
  document.getElementById('contractDate').textContent = dateStr;
  const sigDateEl = document.getElementById('sigDate');
  if (sigDateEl) sigDateEl.value = dateStr;

  // ── Loan calculator
  const rates = { '1':15, '2':25, '3':35, '4':45 };
  function calcLoan() {
    const amt = parseFloat(document.getElementById('loanAmount').value);
    const dur = document.getElementById('loanDuration').value;
    const calc = document.getElementById('loanCalc');
    if (!amt || !dur || amt <= 0) { calc.style.display = 'none'; return; }
    const rate = rates[dur];
    const interest = amt * rate / 100;
    const total = amt + interest;
    const dueDate = new Date();
    dueDate.setDate(dueDate.getDate() + parseInt(dur) * 7);
    document.getElementById('lcPrincipal').textContent = 'ZMW ' + amt.toFixed(2);
    document.getElementById('lcInterest').textContent = 'ZMW ' + interest.toFixed(2);
    document.getElementById('lcTotal').textContent = 'ZMW ' + total.toFixed(2);
    document.getElementById('lcDue').textContent = dueDate.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'});
    calc.style.display = 'flex';
  }

  // ── Submit contract
  function submitContract() {
    const required = [
      { id:'fullName', label:'Full Name' },
      { id:'nrcNumber', label:'NRC Number' },
      { id:'phone', label:'Phone Number' },
      { id:'address', label:'Address' },
      { id:'city', label:'City' },
      { id:'kinName', label:'Next of Kin Name' },
      { id:'kinRelation', label:'Next of Kin Relationship' },
      { id:'kinPhone', label:'Next of Kin Phone' },
      { id:'collateralType', label:'Collateral Type' },
      { id:'collateralBrand', label:'Collateral Brand/Model' },
      { id:'condition', label:'Collateral Condition' },
      { id:'loanAmount', label:'Loan Amount' },
      { id:'loanDuration', label:'Loan Duration' },
      { id:'sigName', label:'Printed Name (Declaration)' },
    ];
    for (const f of required) {
      const el = document.getElementById(f.id);
      if (!el.value.trim()) {
        el.focus();
        el.style.borderColor = '#e53935';
        setTimeout(() => el.style.borderColor = '', 2000);
        alert(`Please fill in: ${f.label}`);
        return;
      }
    }
    if (!document.getElementById('agreeTerms').checked) {
      alert('Please agree to the Terms & Conditions to continue.'); return;
    }
    if (!document.getElementById('agreeCollateral').checked) {
      alert('Please agree to the collateral holding terms to continue.'); return;
    }

    const name = document.getElementById('fullName').value.trim();
    const ref = document.getElementById('contractRef').textContent;

    document.getElementById('contractBody').style.display = 'none';
    const succ = document.getElementById('contractSuccess');
    succ.style.display = 'block';
    document.getElementById('successName').textContent = name;
    document.getElementById('successRef').textContent = ref;
    succ.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>
